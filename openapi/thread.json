{
  "openapi": "3.1.0",
  "info": {
    "title": "Octo Bot Thread API",
    "version": "1.0.0",
    "description": "Thread endpoints under dmworkim /v1/bot. All thread operations are rejected for App Bot."
  },
  "x-octo-service": "thread",
  "x-octo-base-url": "OCTO_API_BASE_URL",
  "x-octo-space-header": false,
  "paths": {
    "/v1/bot/groups/{group_no}/threads": {
      "post": {
        "operationId": "thread.create",
        "summary": "Create a thread in a group (User Bot only)",
        "x-octo-risk": "write",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 100
                  },
                  "source_message_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created thread"
          }
        }
      },
      "get": {
        "operationId": "thread.list",
        "summary": "List threads in a group (User Bot only)",
        "x-octo-risk": "read",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_index",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thread list"
          }
        }
      }
    },
    "/v1/bot/groups/{group_no}/threads/{short_id}": {
      "get": {
        "operationId": "thread.get",
        "summary": "Get thread detail (User Bot only)",
        "x-octo-risk": "read",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thread detail"
          }
        }
      }
    },
    "/v1/bot/groups/{group_no}/threads/{short_id}/members": {
      "get": {
        "operationId": "thread.members",
        "summary": "List thread members (User Bot only)",
        "x-octo-risk": "read",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Members"
          }
        }
      }
    },
    "/v1/bot/groups/{group_no}/threads/{short_id}/join": {
      "post": {
        "operationId": "thread.join",
        "summary": "Bot joins a thread (User Bot only)",
        "x-octo-risk": "write",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Joined"
          }
        }
      }
    },
    "/v1/bot/groups/{group_no}/threads/{short_id}/leave": {
      "post": {
        "operationId": "thread.leave",
        "summary": "Bot leaves a thread (User Bot only)",
        "x-octo-risk": "write",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Left"
          }
        }
      }
    },
    "/v1/bot/groups/{group_no}/threads/{short_id}/md": {
      "get": {
        "operationId": "thread.md-get",
        "summary": "Read thread GROUP.md (User Bot only)",
        "x-octo-risk": "read",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "GROUP.md",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "string"
                    },
                    "version": {
                      "type": "integer"
                    },
                    "updated_at": {
                      "type": "string"
                    },
                    "updated_by": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "thread.md-update",
        "summary": "Update thread GROUP.md (User Bot only; must be bot_admin)",
        "x-octo-risk": "write",
        "parameters": [
          {
            "name": "group_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "content"
                ],
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New version",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "your-octo-instance.com",
          "description": "Your Octo base URL (the CLI's OCTO_API_BASE_URL, without scheme)."
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "botToken": {
        "type": "http",
        "scheme": "bearer",
        "description": "Octo credential as a bearer token: bf_… (User Bot) or app_… (App Bot), or a uk_… user API key. See Security & auth."
      }
    }
  },
  "security": [
    {
      "botToken": []
    }
  ]
}
